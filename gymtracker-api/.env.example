# ── Supabase ─────────────────────────────────────────────────────────────────
# Copie de: Supabase Dashboard → Project Settings → Database → Connection string
# Use "URI" (modo direto, porta 5432) ou "Transaction pooler" (porta 6543).
# O modo direto é recomendado para apps com connection pool próprio (gunicorn).
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].supabase.com:5432/postgres

# ── Segurança ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_64_char_cryptographically_secure_string_here_replace_now
JWT_SECRET_KEY=change_me_another_secure_string_different_from_secret_key_here
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-replace-with-real-key

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://gymtracker.domain.com
